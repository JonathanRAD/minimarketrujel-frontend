// ============================================================
// SCHEMA DE BASE DE DATOS - Sistema Minimarket / Abarrotes
// Motor: PostgreSQL
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// ENUMS
// ============================================================

enum RolUsuario {
  ADMIN
  CAJERO
}

enum MetodoPago {
  EFECTIVO
  TARJETA
  MIXTO
  FIADO
}

enum EstadoVenta {
  COMPLETADA
  ANULADA
}

enum EstadoCompra {
  PENDIENTE
  RECIBIDA
  CANCELADA
}

enum UnidadMedida {
  UNIDAD
  KG
  G
  LITRO
  ML
}

enum TipoMovimientoInventario {
  VENTA
  COMPRA
  AJUSTE
  MERMA
  DEVOLUCION
}

enum EstadoTurno {
  ABIERTO
  CERRADO
}

// ============================================================
// USUARIOS Y AUTENTICACIÓN
// ============================================================

model Usuario {
  id           String     @id @default(uuid())
  nombre       String
  email        String     @unique
  passwordHash String     @map("password_hash")
  pin          String?    @unique // PIN de 4 dígitos para acceso rápido en POS
  rol          RolUsuario @default(CAJERO)
  activo       Boolean    @default(true)
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  ventas              Venta[]
  compras             Compra[]
  movimientosInventario MovimientoInventario[]
  turnosCaja          TurnoCaja[]

  @@map("usuarios")
}

// ============================================================
// CATÁLOGO DE PRODUCTOS
// ============================================================

model Categoria {
  id          String   @id @default(uuid())
  nombre      String
  descripcion String?
  activo      Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")

  productos Producto[]

  @@map("categorias")
}

model Producto {
  id            String       @id @default(uuid())
  nombre        String
  descripcion   String?
  categoriaId   String?      @map("categoria_id")
  codigoBarras  String       @unique @map("codigo_barras")
  precioVenta   Decimal      @map("precio_venta") @db.Decimal(10, 2)
  costo         Decimal      @db.Decimal(10, 2)
  stockActual   Decimal      @default(0) @map("stock_actual") @db.Decimal(10, 2)
  stockMinimo   Decimal      @default(5) @map("stock_minimo") @db.Decimal(10, 2)
  unidadMedida  UnidadMedida @default(UNIDAD) @map("unidad_medida")
  activo        Boolean      @default(true)
  imagenUrl     String?      @map("imagen_url")
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")

  categoria             Categoria?              @relation(fields: [categoriaId], references: [id])
  ventaDetalles         VentaDetalle[]
  compraDetalles        CompraDetalle[]
  movimientosInventario MovimientoInventario[]

  @@index([codigoBarras])
  @@index([categoriaId])
  @@map("productos")
}

// ============================================================
// PROVEEDORES Y COMPRAS
// ============================================================

model Proveedor {
  id        String   @id @default(uuid())
  nombre    String
  contacto  String?
  telefono  String?
  email     String?
  direccion String?
  activo    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")

  compras Compra[]

  @@map("proveedores")
}

model Compra {
  id           String       @id @default(uuid())
  proveedorId  String       @map("proveedor_id")
  usuarioId    String       @map("usuario_id")
  fecha        DateTime     @default(now())
  total        Decimal      @db.Decimal(10, 2)
  estado       EstadoCompra @default(PENDIENTE)
  createdAt    DateTime     @default(now()) @map("created_at")

  proveedor Proveedor       @relation(fields: [proveedorId], references: [id])
  usuario   Usuario         @relation(fields: [usuarioId], references: [id])
  detalles  CompraDetalle[]

  @@index([proveedorId])
  @@index([fecha])
  @@map("compras")
}

model CompraDetalle {
  id            String  @id @default(uuid())
  compraId      String  @map("compra_id")
  productoId    String  @map("producto_id")
  cantidad      Decimal @db.Decimal(10, 2)
  costoUnitario Decimal @map("costo_unitario") @db.Decimal(10, 2)
  subtotal      Decimal @db.Decimal(10, 2)

  compra   Compra   @relation(fields: [compraId], references: [id], onDelete: Cascade)
  producto Producto @relation(fields: [productoId], references: [id])

  @@index([compraId])
  @@map("compra_detalle")
}

// ============================================================
// CLIENTES Y FIADOS
// ============================================================

model Cliente {
  id             String   @id @default(uuid())
  nombre         String
  telefono       String?
  direccion      String?
  limiteCredito  Decimal  @default(0) @map("limite_credito") @db.Decimal(10, 2)
  activo         Boolean  @default(true)
  createdAt      DateTime @default(now()) @map("created_at")

  ventas Venta[]
  fiados Fiado[]

  @@map("clientes")
}

model Fiado {
  id           String    @id @default(uuid())
  clienteId    String    @map("cliente_id")
  ventaId      String    @unique @map("venta_id")
  monto        Decimal   @db.Decimal(10, 2)
  pagado       Boolean   @default(false)
  fechaLimite  DateTime? @map("fecha_limite")
  createdAt    DateTime  @default(now()) @map("created_at")

  cliente Cliente @relation(fields: [clienteId], references: [id])
  venta   Venta   @relation(fields: [ventaId], references: [id])

  @@index([clienteId])
  @@map("fiados")
}

// ============================================================
// VENTAS
// ============================================================

model Venta {
  id            String      @id @default(uuid()) // UUID generado en cliente (offline-first)
  usuarioId     String      @map("usuario_id")
  clienteId     String?     @map("cliente_id")
  turnoId       String?     @map("turno_id")
  fecha         DateTime    @default(now())
  total         Decimal     @db.Decimal(10, 2)
  metodoPago    MetodoPago  @default(EFECTIVO) @map("metodo_pago")
  montoEfectivo Decimal     @default(0) @map("monto_efectivo") @db.Decimal(10, 2)
  montoTarjeta  Decimal     @default(0) @map("monto_tarjeta") @db.Decimal(10, 2)
  estado        EstadoVenta @default(COMPLETADA)
  sincronizado  Boolean     @default(true) // útil para trazar ventas offline
  createdAt     DateTime    @default(now()) @map("created_at")

  usuario  Usuario        @relation(fields: [usuarioId], references: [id])
  cliente  Cliente?       @relation(fields: [clienteId], references: [id])
  turno    TurnoCaja?     @relation(fields: [turnoId], references: [id])
  detalles VentaDetalle[]
  fiado    Fiado?

  @@index([fecha])
  @@index([usuarioId])
  @@index([turnoId])
  @@map("ventas")
}

model VentaDetalle {
  id             String  @id @default(uuid())
  ventaId        String  @map("venta_id")
  productoId     String  @map("producto_id")
  cantidad       Decimal @db.Decimal(10, 2)
  precioUnitario Decimal @map("precio_unitario") @db.Decimal(10, 2)
  subtotal       Decimal @db.Decimal(10, 2)

  venta    Venta    @relation(fields: [ventaId], references: [id], onDelete: Cascade)
  producto Producto @relation(fields: [productoId], references: [id])

  @@index([ventaId])
  @@map("venta_detalle")
}

// ============================================================
// INVENTARIO (AUDITORÍA)
// ============================================================

model MovimientoInventario {
  id            String                   @id @default(uuid())
  productoId    String                   @map("producto_id")
  tipo          TipoMovimientoInventario
  cantidad      Decimal                  @db.Decimal(10, 2) // positivo o negativo
  motivo        String?
  usuarioId     String                   @map("usuario_id")
  referenciaId  String?                  @map("referencia_id") // id de venta o compra relacionada
  fecha         DateTime                 @default(now())

  producto Producto @relation(fields: [productoId], references: [id])
  usuario  Usuario  @relation(fields: [usuarioId], references: [id])

  @@index([productoId])
  @@index([fecha])
  @@map("movimientos_inventario")
}

// ============================================================
// TURNOS DE CAJA
// ============================================================

model TurnoCaja {
  id                  String      @id @default(uuid())
  usuarioId           String      @map("usuario_id")
  fechaApertura       DateTime    @default(now()) @map("fecha_apertura")
  fechaCierre         DateTime?   @map("fecha_cierre")
  montoInicial        Decimal     @map("monto_inicial") @db.Decimal(10, 2)
  montoFinalEsperado  Decimal?    @map("monto_final_esperado") @db.Decimal(10, 2)
  montoFinalReal      Decimal?    @map("monto_final_real") @db.Decimal(10, 2)
  diferencia          Decimal?    @db.Decimal(10, 2)
  estado              EstadoTurno @default(ABIERTO)
  auditoriaArqueo     Json?       @map("auditoria_arqueo")

  usuario Usuario @relation(fields: [usuarioId], references: [id])
  ventas  Venta[]

  @@index([usuarioId])
  @@index([estado])
  @@map("turnos_caja")
}
