PORT=3000
NODE_ENV=development

# PostgreSQL - reemplaza con tus credenciales reales
DATABASE_URL="postgresql://usuario:password@localhost:5432/minimarket?schema=public"

# JWT
JWT_SECRET="cambia_esto_por_un_secreto_largo_y_random"
JWT_EXPIRES_IN="8h"

# CORS - dominios permitidos separados por coma
CORS_ORIGINS="http://localhost:4200"

# Gmail OAuth2 - Autocompletado mediante el script 'npm run setup:gmail'
GMAIL_USER_EMAIL=""
GMAIL_CLIENT_ID=""
GMAIL_CLIENT_SECRET=""
GMAIL_REFRESH_TOKEN=""
GMAIL_ADMIN_RECIPIENT=""

